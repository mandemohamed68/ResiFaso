# ==========================================
# CONFIGURATION VITE (FRONTEND REACT)
# Les variables exposées au navigateur doivent commencer par VITE_
# ==========================================

# URL de l'API Backend (Remplacez par l'IP de votre serveur local)
VITE_API_URL=http://41.78.54.60:5000/api

# === CONFIGURATION FIREBASE ===
# (Vous trouverez ces informations dans le fichier `firebase-applet-config.json` à la racine de votre projet actuel, 
# ou dans la console Firebase (Paramètres du projet > Général > Vos applications) si vous créez un nouveau projet).
VITE_FIREBASE_API_KEY="votre_api_key_firebase"
VITE_FIREBASE_AUTH_DOMAIN="votre-projet.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="votre-projet-id"
VITE_FIREBASE_STORAGE_BUCKET="votre-projet.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="votre_sender_id"
VITE_FIREBASE_APP_ID="votre_app_id"
VITE_FIREBASE_MEASUREMENT_ID="votre_measurement_id"

# ==========================================
# CONFIGURATION DU SERVEUR BACKEND (NODE.JS)
# Ces variables sont secrètes et restent sur le serveur
# ==========================================

# Port interne d'écoute du serveur Node.js (Sur 3000, car Nginx écoute le 4000)
PORT=3000
NODE_ENV=development

# === CONFIGURATION MARIADB / MYSQL (POUR LE DÉPLOIEMENT DEBIAN) ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=resifaso_user
DB_PASSWORD="MOT_DE_PASSE_TRES_FORT_ICI"
DB_NAME=resifaso_db

# Si vous utilisez un ORM comme Drizzle ou Prisma pour MariaDB :
DATABASE_URL="mysql://resifaso_user:MOT_DE_PASSE_TRES_FORT_ICI@127.0.0.1:3306/resifaso_db"

# Clé secrète pour authentification personnalisée (alternative à Firebase Auth)
JWT_SECRET="une_cle_tres_longue_aleatoire_et_secrete_12345"

# ==========================================
# CONFIGURATIONS EXISTANTES & API EXTERNES
# ==========================================

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

